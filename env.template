# PIDlab — Local Environment
#
# Copy to .env.local:  cp env.template .env.local
# Fill in real values from 1Password (vault: PIDlab Infrastructure)
#
# Scripts auto-load .env.local from repo root. No need to manually source it.
# All admin scripts default to DEV environment.
# To target PROD: PIDLAB_ENV=prod ./infrastructure/scripts/generate-key.sh ...

# ═══════════════════════════════════════════════════════════════════
# WORKER URLS (fixed, no secrets)
# ═══════════════════════════════════════════════════════════════════
TELEMETRY_DEV_URL="https://pidlab-telemetry-dev.eddycek-ve.workers.dev"
TELEMETRY_PROD_URL="https://telemetry.pidlab.app"
LICENSE_DEV_URL="https://pidlab-license-dev.eddycek-ve.workers.dev"
LICENSE_PROD_URL="https://license.pidlab.app"

# ═══════════════════════════════════════════════════════════════════
# TELEMETRY ADMIN KEYS
# ═══════════════════════════════════════════════════════════════════
# For /admin/stats/* endpoints. Generate with: openssl rand -hex 32
# GitHub secrets: TELEMETRY_ADMIN_KEY_DEV, TELEMETRY_ADMIN_KEY_PROD
TELEMETRY_ADMIN_KEY_DEV=""
TELEMETRY_ADMIN_KEY_PROD=""

# ═══════════════════════════════════════════════════════════════════
# LICENSE ADMIN KEYS
# ═══════════════════════════════════════════════════════════════════
# For /admin/keys/* endpoints. Generate with: openssl rand -hex 32
# GitHub secrets: LICENSE_ADMIN_KEY_DEV, LICENSE_ADMIN_KEY_PROD
LICENSE_ADMIN_KEY_DEV=""
LICENSE_ADMIN_KEY_PROD=""

# ═══════════════════════════════════════════════════════════════════
# ED25519 KEYPAIR (license signing)
# ═══════════════════════════════════════════════════════════════════
# Generate with: ./infrastructure/scripts/generate-ed25519-keypair.sh
# CRITICAL: Back up in 1Password — losing these invalidates all issued licenses
# GitHub secrets: LICENSE_ED25519_PRIVATE_KEY, LICENSE_ED25519_PUBLIC_KEY
# Public key also in: src/shared/constants.ts → LICENSE.ED25519_PUBLIC_KEY
LICENSE_ED25519_PRIVATE_KEY=""
LICENSE_ED25519_PUBLIC_KEY=""

# ═══════════════════════════════════════════════════════════════════
# TERRAFORM (only needed for manual infrastructure operations)
# ═══════════════════════════════════════════════════════════════════
# R2 state backend — GitHub secrets: TERRAFORM_STATE_R2_ACCESS_KEY_ID, ..._SECRET_ACCESS_KEY
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
# CF API token — GitHub secret: CLOUDFLARE_PROVISIONING
export TF_VAR_cloudflare_api_token=""
# Resend email — GitHub secret: RESEND_API_KEY
export TF_VAR_resend_api_key=""
